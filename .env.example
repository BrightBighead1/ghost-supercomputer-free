# Ghost SuperComputer — Environment Variables
# Copy this to .env and fill in your values

# ============================================================
# GENERAL
# ============================================================
GHOST_ENV=production
GHOST_PUBLIC_HOST=ghost.yourdomain.com
TZ=UTC

# ============================================================
# NEON DATABASE
# ============================================================
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
NEON_DB_HOST=ep-xxx.us-east-2.aws.neon.tech
NEON_DB_NAME=neondb
NEON_DB_USER=your_user
NEON_DB_PASSWORD=your_password

# ============================================================
# SUPABASE
# ============================================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_KEY=eyJxxx...

# ============================================================
# CLOUDFLARE
# ============================================================
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_zone_id
CF_ACCOUNT_ID=your_account_id
CF_R2_BUCKET=ghost-storage
CF_R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
CF_R2_ACCESS_KEY_ID=your_r2_access_key
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CF_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ============================================================
# LLM API KEYS (use free tiers)
# ============================================================
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GITHUB_TOKEN=ghp_xxx

# ============================================================
# SUGA.APP (set after creating service)
# ============================================================
SUGA_HOST=ghost-xxx.suga.app
SUGA_PORT=3333

# ============================================================
# N8N
# ============================================================
N8N_ENCRYPTION_KEY=change_me_to_random_string

# ============================================================
# POCKETBASE
# ============================================================
POCKETBASE_ADMIN_EMAIL=admin@ghost.local
POCKETBASE_ADMIN_PASSWORD=change_me_now
