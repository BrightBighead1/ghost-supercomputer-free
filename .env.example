# Ghost SuperComputer — Environment Variables
# Copy this to .env and fill in your values

# ============================================================
# GENERAL
# ============================================================
GHOST_ENV=production
GHOST_PUBLIC_HOST=ghost.yourdomain.com
TZ=UTC

# ============================================================
# SUGA.APP — All services come from Suga templates
# ============================================================

# PostgreSQL (Suga template: PostgreSQL)
DATABASE_URL=postgresql://user:pass@postgres:5432/ghost?sslmode=require

# PocketBase (Suga template: PocketBase)
POCKETBASE_URL=http://pocketbase:8090
POCKETBASE_ANON_KEY=your_pocketbase_anon_key
POCKETBASE_ADMIN_EMAIL=admin@ghost.local
POCKETBASE_ADMIN_PASSWORD=change_me_now

# MinIO (Suga template: MinIO)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# Meilisearch (Suga template: Meilisearch)
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=your_meilisearch_master_key

# LiteLLM (Suga template: LiteLLM)
LITELLM_URL=http://litellm:4000

# ============================================================
# LLM API KEYS (configure in LiteLLM)
# ============================================================
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GITHUB_TOKEN=ghp_xxx

# ============================================================
# SUGA.APP — Your service URL
# ============================================================
SUGA_HOST=ghost-xxx.suga.app
SUGA_PORT=3333
