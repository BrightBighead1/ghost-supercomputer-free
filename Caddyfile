{$GHOST_PUBLIC_HOST:localhost} {
    handle /agent/* {
        reverse_proxy ghost-gitagent:3333
    }

    handle /n8n/* {
        uri strip_prefix /n8n
        reverse_proxy ghost-n8n:5678
    }

    handle /pb/* {
        uri strip_prefix /pb
        reverse_proxy ghost-pocketbase:8090
    }

    handle {
        reverse_proxy ghost-gitagent:3333
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output stdout
        format json
    }
}
